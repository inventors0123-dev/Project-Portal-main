# Required for production (Render/Vercel)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME
ADMIN_PASSWORD=replace-with-a-strong-password

# Google Drive parent folder where project folders are created
DRIVE_PARENT_FOLDER_ID=your_google_drive_parent_folder_id

# Whether Google should send permission emails when users are added
SEND_PERMISSION_EMAIL=true

# Google Drive auth (recommended: use this env var on cloud)
# Put the full service account JSON as a single-line JSON string.
GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"your-project","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"...","universe_domain":"googleapis.com"}

# Optional local file fallback when GOOGLE_CREDENTIALS_JSON is not set
SERVICE_ACCOUNT_FILE=credentials.json

# Optional local debug
FLASK_DEBUG=false
